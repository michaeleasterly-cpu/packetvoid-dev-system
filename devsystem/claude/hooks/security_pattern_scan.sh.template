#!/usr/bin/env bash
# PostToolUse(Edit|Write|MultiEdit|NotebookEdit) — Layer 1 security
# pattern scan. Thin bash wrapper around security_pattern_scan.py so the
# hook integrates with the project's bash-script hook convention.
#
# Kill switch: DEVSYS_SECURITY_PATTERN_SCAN_DISABLE=1
#
# Vendored from anthropics/claude-code plugins/security-guidance Layer 1
# ("pattern-based rules") — Layer 1 ONLY. Layers 2 + 3 (Stop-hook LLM diff
# review, agentic commit/push review) are intentionally not vendored: their
# cost is unmeasured and they require an Anthropic API budget the generic
# scaffold should not assume.
#
# Advisory only: this hook NEVER blocks an edit (PostToolUse cannot block
# retroactively per https://code.claude.com/docs/en/hooks); it emits a
# reminder via the hook's additionalContext output.
#
# Authoritative external:
#   - https://code.claude.com/docs/en/hooks
#   - https://github.com/anthropics/claude-code
#
# Project: {{ project_name }}
set -e

# Allow override via env, otherwise prefer the project venv's python then
# fall back to system python3/python.
PY="${DEVSYS_SECURITY_PATTERN_SCAN_PYTHON:-}"
if [ -z "$PY" ]; then
  if [ -x "${CLAUDE_PROJECT_DIR}/.venv/bin/python" ]; then
    PY="${CLAUDE_PROJECT_DIR}/.venv/bin/python"
  elif command -v python3 >/dev/null 2>&1; then
    PY="python3"
  elif command -v python >/dev/null 2>&1; then
    PY="python"
  else
    # No python available — advisory hook, never block.
    exit 0
  fi
fi

exec "$PY" "$(dirname "$0")/security_pattern_scan.py"
